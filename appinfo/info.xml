<?xml version="1.0"?>
<info xmlns:xsi= "http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>vapor</id>
    <name>Vapor</name>
    <summary>Vapor – condensing the web into your cloud</summary>
    <description>
Search for torrents within the app from multiple BT sites;
Control Aria2 and manage download tasks from the web;
Download videos from 700+ video sites (youtube,youku,vimo,dailymotion,twitter,facebook and the likes).
    </description>
    <version>1.0.2</version>
    <licence>AGPL-3.0-or-later</licence>
    <author mail="freefallbenson@gmail.com" homepage="https://github.com/shiningw">jiaxinhuang</author>
    <author mail="wolfravenous@gmail.com" homepage="https://github.com/wolfravenous">wolfravenous</author>
    <namespace>Vapor</namespace>
    <category>tools</category>
    <website>https://github.com/wolfravenous/vapor</website>
    <bugs>https://github.com/wolfravenous/vapor/issues</bugs>
    <screenshot>https://user-images.githubusercontent.com/3911975/142444998-54dd54a6-0c8e-4d49-8188-270964a99c50.png</screenshot>
    <screenshot>https://user-images.githubusercontent.com/3911975/142445020-27ec389a-5437-4d28-acc0-5e757fd6897d.png</screenshot>
    <repository>https://github.com/wolfravenous/vapor</repository>
    <dependencies>
        <php min-version="8.3" max-version="8.5" />
        <nextcloud min-version="32" max-version="34"/>
    </dependencies>
    <navigations>
        <navigation>
            <name>Vapor</name>
            <route>vapor.Main.Index</route>
            <icon>vapor.svg</icon>
        </navigation>
    </navigations>
    <settings>
        <admin>OCA\Vapor\Settings\Admin</admin>
        <personal>OCA\Vapor\Settings\Personal</personal>
        <admin-section>OCA\Vapor\Settings\AdminSection</admin-section>
        <personal-section>OCA\Vapor\Settings\PersonalSection</personal-section>
    </settings>
    <commands>
        <command>OCA\Vapor\Command\Aria2Command</command>
    </commands>

</info>
